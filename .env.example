# .env.example — EIA-Agent v2.1
# Plantilla de variables de entorno del proyecto.
#
# INSTRUCCIONES:
#   1. Copia este archivo como .env:
#        Windows:  copy .env.example .env
#        macOS/Linux: cp .env.example .env
#   2. Rellena las claves que necesites (ver descripción de cada una).
#   3. NUNCA subas .env a git — contiene claves privadas.
#
# Todas las claves son OPCIONALES para instalar el entorno.
# El sistema mostrará avisos si una clave falta cuando se necesite.

# ── AEMET — Agencia Estatal de Meteorología ───────────────────────────────
# Necesaria para: AG-07 (clima), generación de climograma, clasificación
# climática Köppen-Geiger e índice de Martonne.
# Obtener en: https://opendata.aemet.es/centrodedescargas/altaUsuario
AEMET_API_KEY=

# ── Mapbox — Mapas base opcionales ────────────────────────────────────────
# Necesaria para: mapas base de alta resolución (WMS alternativo).
# El sistema funciona sin esta clave usando los WMS institucionales
# (IDECanarias, GRAFCAN, Catastro). Solo necesaria si se quieren
# mapas base de Mapbox como fallback adicional.
# Obtener en: https://account.mapbox.com/
MAPBOX_TOKEN=

# ── OpenAI — Modelo alternativo (opcional) ────────────────────────────────
# El sistema usa Claude (Anthropic) por defecto.
# Solo necesaria si se configura un agente con modelo GPT como fallback.
OPENAI_API_KEY=

# ── Entorno de ejecución ──────────────────────────────────────────────────
# local   → ejecución en máquina del técnico (sin restricciones de red)
# ci      → ejecución en integración continua (mocks de APIs externas)
# prod    → ejecución en servidor (requiere todas las claves configuradas)
EIA_ENV=local
