{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "eia-agent:v2.1:common_defs",
  "title": "EIA-Agent v2.1 — definiciones reutilizables",
  "description": "Tipos, enums y patrones compartidos por los 6 schemas de capa. Nunca se valida directamente — se referencia con $ref desde otros schemas.",
  "$defs": {
    "EvidenceState": {
      "title": "Estado de evidencia",
      "description": "Estados canonicos definidos en src/eia_agent/core/evidence_state.py. DESCARTADO se mantiene por compatibilidad.",
      "type": "string",
      "enum": [
        "CONFIRMADO_CAMPO",
        "CONFIRMADO_GABINETE",
        "CONFIRMADO",
        "DECLARADO",
        "ASUNCION_TEST",
        "INFERIDO_TECNICO",
        "INFERIDO",
        "LIMITADO_ESCALA",
        "ESTIMADO",
        "PROVISIONAL",
        "PENDIENTE_VERIFICACION",
        "PENDIENTE",
        "NO_CONSTA",
        "DESCARTADO",
        "ERROR"
      ]
    },

    "Criticidad": {
      "title": "Nivel de criticidad",
      "description": "Valores admitidos en los campos criticidad. Se incluyen variantes reales detectadas en ambos pilotos.",
      "type": "string",
      "enum": [
        "CRITICA",
        "CRÍTICA",
        "ALTA",
        "MEDIA-ALTA",
        "MODERADA-ALTA",
        "MEDIA",
        "MODERADA",
        "BAJA-MEDIA",
        "BAJA",
        "INFORMATIVA",
        "RESUELTO",
        "RESUELTA"
      ]
    },

    "FechaISO": {
      "title": "Fecha en formato ISO 8601 (YYYY-MM-DD)",
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },

    "RutaRelativa": {
      "title": "Ruta relativa al directorio del expediente o texto N/A",
      "description": "Puede ser una ruta relativa (con / o \\) o texto empezando por 'N/A'.",
      "type": "string",
      "minLength": 1
    },

    "IdHechoConfirmado": {
      "title": "ID de hecho confirmado",
      "description": "Patron HC-001, HC-T001, HC-T-001 o variantes usadas en pilotos.",
      "type": "string",
      "pattern": "^HC(-T)?-?[0-9]{3,4}$"
    },

    "IdInferenciaGap": {
      "title": "ID de inferencia o gap",
      "description": "Admite CONT, GAP, INF, PS-INF, CAUTELA y variantes con sufijo de expediente.",
      "type": "string",
      "pattern": "^(CONT|GAP|INF|PS-INF|CAUTELA)(-[A-Z0-9]+)?-[0-9]{3,4}$"
    },

    "IdNormativa": {
      "title": "ID de normativa",
      "type": "string",
      "pattern": "^NJ-[0-9]{3}$"
    },

    "IdTrazabilidad": {
      "title": "ID de trazabilidad",
      "description": "Patron TR-001 o TR-T-001.",
      "type": "string",
      "pattern": "^TR(-T)?-?[0-9]{3,4}$"
    },

    "IdCartografia": {
      "title": "ID de entrada cartografica",
      "type": "string",
      "pattern": "^CT-[0-9]{3}$"
    },

    "IdSalida": {
      "title": "ID de salida generada",
      "type": "string",
      "pattern": "^SG-[0-9]{3}$"
    },

    "EstadoCartografia": {
      "title": "Estado de un elemento cartografico",
      "type": "string",
      "enum": [
        "GENERADO",
        "GENERADO_MODO_TEST",
        "PROVISIONAL",
        "VERIFICADO",
        "PENDIENTE",
        "ERROR",
        "FALLBACK"
      ]
    },

    "TipoCartografia": {
      "title": "Tipo de elemento cartografico",
      "type": "string",
      "enum": [
        "VERIFICACION_INTERNA",
        "GENERADO_AUTOMATICAMENTE",
        "WMS",
        "WFS",
        "RASTER",
        "VECTOR",
        "MAPA_PROVISIONAL"
      ]
    },

    "EstadoNormativa": {
      "title": "Estado de verificacion de una norma",
      "description": "Variantes admitidas detectadas en ambos pilotos.",
      "type": "string",
      "enum": [
        "VERIFICADA",
        "VERIFICADA ONLINE",
        "VERIFICADO",
        "REFERENCIADA",
        "PENDIENTE",
        "INFERIDA",
        "RESUELTO",
        "ERROR"
      ]
    },

    "ArrayStringNoVacio": {
      "title": "Array de strings no vacio",
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    }
  }
}
